<section class="monthly-menu" style="background-color: {{ section.settings.bg_color }}">
  <div class="monthly-menu__inner">
    <div class="monthly-menu__header">
      <p class="monthly-menu__label">{{ section.settings.label }}</p>
      <h2 class="monthly-menu__title">{{ section.settings.title }}</h2>
      <p class="monthly-menu__subtitle">{{ section.settings.subtitle }}</p>
    </div>

    <div class="monthly-menu__grid">
      {% for block in section.blocks %}
        <div class="menu-card" {{ block.shopify_attributes }}>
          <div class="menu-card__icon">🍲</div>
          <h3 class="menu-card__name">{{ block.settings.soup_name }}</h3>
          <p class="menu-card__chinese">{{ block.settings.soup_chinese }}</p>
          <p class="menu-card__ingredients">{{ block.settings.ingredients }}</p>
          <p class="menu-card__price">{{ block.settings.price }}</p>
        </div>
      {% endfor %}
    </div>

    <div class="monthly-menu__cta">
      <p>{{ section.settings.order_note }}</p>
      <a href="{{ section.settings.order_url }}" class="monthly-menu__btn">
        {{ section.settings.button_text }}
      </a>
    </div>
  </div>
</section>

{% stylesheet %}
  .monthly-menu {
    padding: 80px 24px;
  }

  .monthly-menu__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .monthly-menu__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .monthly-menu__label {
    font-size: 0.85rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #C41E3A;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .monthly-menu__title {
    font-size: 2.5rem;
    color: #2C1810;
    margin-bottom: 12px;
    font-weight: 800;
  }

  .monthly-menu__subtitle {
    color: #6B4C3B;
    font-size: 1rem;
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .monthly-menu__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }

  .menu-card {
    background: #fff;
    border-radius: 16px;
    padding: 28px 24px;
    box-shadow: 0 2px 16px rgba(196, 30, 58, 0.08);
    border: 1px solid #FFE8E8;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .menu-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(196, 30, 58, 0.15);
  }

  .menu-card__icon {
    font-size: 2.5rem;
    margin-bottom: 16px;
  }

  .menu-card__name {
    font-size: 1rem;
    font-weight: 700;
    color: #2C1810;
    margin-bottom: 4px;
    line-height: 1.4;
  }

  .menu-card__chinese {
    font-size: 0.9rem;
    color: #C41E3A;
    margin-bottom: 12px;
    font-weight: 500;
  }

  .menu-card__ingredients {
    font-size: 0.85rem;
    color: #6B4C3B;
    line-height: 1.5;
    margin-bottom: 16px;
  }

  .menu-card__price {
    font-size: 1.1rem;
    font-weight: 700;
    color: #C41E3A;
  }

  .monthly-menu__cta {
    text-align: center;
  }

  .monthly-menu__cta p {
    color: #6B4C3B;
    margin-bottom: 20px;
    font-size: 0.95rem;
  }

  .monthly-menu__btn {
    display: inline-block;
    background: #C41E3A;
    color: #fff;
    padding: 16px 40px;
    border-radius: 50px;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    transition: background 0.2s;
  }

  .monthly-menu__btn:hover {
    background: #a01830;
  }

  @media (max-width: 900px) {
    .monthly-menu__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .monthly-menu__grid {
      grid-template-columns: 1fr;
    }

    .monthly-menu__title {
      font-size: 1.8rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Monthly Menu",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "This Month's Selection"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "May Menu 五月湯單"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Fresh daily · 每日新鮮製造 · Made with love"
    },
    {
      "type": "text",
      "id": "order_note",
      "label": "Order Note",
      "default": "DM us on Instagram to place your order · 請私訊我們落單"
    },
    {
      "type": "url",
      "id": "order_url",
      "label": "Order Button Link"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Order Now · 立即落單"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFF8F0"
    }
  ],
  "blocks": [
    {
      "type": "soup",
      "name": "Soup Item",
      "settings": [
        {
          "type": "text",
          "id": "soup_name",
          "label": "Soup Name (English)"
        },
        {
          "type": "text",
          "id": "soup_chinese",
          "label": "Soup Name (Chinese)"
        },
        {
          "type": "textarea",
          "id": "ingredients",
          "label": "Ingredients"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$15"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Monthly Menu"
    }
  ]
}
{% endschema %}